    def save(self):
        if self.sol is None: return
        np.save("sol_2d.npy", self.sol)
        np.save("x_2d.npy",   self.x)
        np.save("y_2d.npy",   self.y)
        # Guardar metadata para que load() reconstruya correctamente
        np.save("meta_2d.npy", np.array([
            self.Nx, self.Ny,
            float(self.edt.get()), float(self.eNt.get())
        ]))
        self._set_status("● GUARDADO", SUCCESS)
        self.root.after(2000, lambda: self._set_status("● LISTO", SUCCESS))

    def load(self):
        if not os.path.exists("sol_2d.npy"):
            self._set_status("● No se encontró sol_2d.npy", DANGER)
            return
        self.sol = np.load("sol_2d.npy")
        self.x   = np.load("x_2d.npy")
        self.y   = np.load("y_2d.npy")
        # Leer metadata si existe, si no inferir de las dimensiones del array
        if os.path.exists("meta_2d.npy"):
            meta = np.load("meta_2d.npy")
            Nx, Ny = int(meta[0]), int(meta[1])
            # Restaurar parámetros en la UI
            for entry, val in [(self.eNx, str(Nx)), (self.eNy, str(Ny)),
                               (self.edt, str(meta[2])), (self.eNt, str(int(meta[3])))]:
                entry.delete(0, tk.END)
                entry.insert(0, val)
        else:
            Nx = len(self.x)
            Ny = len(self.y)
        self.Nx, self.Ny = Nx, Ny
        self.x, self.y, self.XX, self.YY, hx, hy = crear_malla_2d(Nx, Ny)
        self.hx, self.hy = hx, hy
        M_csr, K_csr = ensamblar_2d_lil(Nx, Ny, hx, hy)
        V_2d   = potencial_2d(self.XX, self.YY, self.var_pot.get())
        V_flat = V_2d.ravel()
        self.M_csr  = M_csr
        self.K_csr  = K_csr
        self.V_csr  = ensamblar_V_2d_dok(V_flat)
        self.V_flat = V_flat
        self._plot_final(Nx, Ny, len(self.sol) - 1, float(self.edt.get()))
        self._set_status("● CARGADO", INFO)
        self.root.after(2000, lambda: self._set_status("● LISTO", SUCCESS))

    def reset(self):
        for e, v in [(self.eNx, "40"), (self.eNy, "40"),
                     (self.edt, "0.005"), (self.eNt, "200"),
                     (self.ex0, "-3.0"), (self.esx, "1.0"), (self.ekx, "2.0")]:
            e.delete(0, tk.END)
            e.insert(0, v)
        self.var_pot.set("Libre")
        self.progress["value"] = 0
        # Limpiar estado completamente
        self.sol  = None
        self.x    = self.y   = None
        self.XX   = self.YY  = None
        self.Nx   = self.Ny  = None
        self._ani = None
        for attr in ("M_csr", "K_csr", "V_csr", "V_flat", "hx", "hy", "_colorbar"):
            if hasattr(self, attr):
                delattr(self, attr)
        # Restablecer gráfica
        self.ax.clear()
        aplicar_tema_ax(self.ax, "")
        self.ax.text(0.5, 0.5, "Sin datos",
                     ha="center", va="center",
                     color=DIM, fontsize=14, fontfamily="monospace",
                     transform=self.ax.transAxes)
        self.canvas_plot.draw()
        self.lbl_plot_title.config(text="Sin datos — ejecuta la simulación", fg=MUTED)
        self._set_status("● LISTO", DIM)

    def load_input_file(self):
        """Carga parámetros de simulación desde un archivo JSON."""
        path = filedialog.askopenfilename(
            title="Cargar parámetros",
            filetypes=[("JSON", "*.json"), ("Todos", "*.*")])
        if not path:
            return
        try:
            with open(path, "r", encoding="utf-8") as f:
                params = json.load(f)
            fields = {
                "Nx": self.eNx, "Ny": self.eNy,
                "dt": self.edt, "Nt": self.eNt,
                "x0": self.ex0, "sx": self.esx, "kx": self.ekx,
            }
            for key, entry in fields.items():
                if key in params:
                    entry.delete(0, tk.END)
                    entry.insert(0, str(params[key]))
            if "potencial" in params:
                self.var_pot.set(params["potencial"])
            self._set_status(f"● Parámetros cargados: {os.path.basename(path)}", SUCCESS)
        except Exception as e:
            messagebox.showerror("Error", f"No se pudo leer el archivo:\n{e}")

    def save_input_file(self):
        """Guarda los parámetros actuales de la UI en un archivo JSON."""
        path = filedialog.asksaveasfilename(
            title="Guardar parámetros",
            defaultextension=".json",
            filetypes=[("JSON", "*.json")])
        if not path:
            return
        params = {
            "Nx":        int(self.eNx.get()),
            "Ny":        int(self.eNy.get()),
            "dt":        float(self.edt.get()),
            "Nt":        int(self.eNt.get()),
            "x0":        float(self.ex0.get()),
            "sx":        float(self.esx.get()),
            "kx":        float(self.ekx.get()),
            "potencial": self.var_pot.get(),
        }
        with open(path, "w", encoding="utf-8") as f:
            json.dump(params, f, indent=2, ensure_ascii=False)
        self._set_status(f"● Parámetros guardados: {os.path.basename(path)}", SUCCESS)

    def _set_status(self, text, color):
        self.lbl_status.config(text=text, fg=color)



