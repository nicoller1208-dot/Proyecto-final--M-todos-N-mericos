    def _check_sol(self):
        """Verifica que haya solución y matrices disponibles."""
        if self.sol is None:
            self._set_status("● Ejecuta primero la simulación", DANGER)
            return False
        if not hasattr(self, "M_csr"):
            self._set_status("● Faltan matrices — re-ejecuta o carga", DANGER)
            return False
        return True

    def norma(self):
        if not self._check_sol(): return
        norms = [np.real(np.dot(np.conj(p), self.M_csr @ p)) for p in self.sol]
        dt_val = float(self.edt.get())
        t_axis = np.arange(len(norms)) * dt_val
        fig, ax = fig_externa(figsize=(8, 5))
        ax.plot(t_axis, norms, color=SUCCESS, lw=1.8, label="ψ†Mψ (FEM)")
        ax.axhline(1, color=DIM, ls="--", lw=1.0, label="ideal = 1")
        # Banda de error ±0.1%
        ax.fill_between(t_axis, 0.999, 1.001, color=SUCCESS, alpha=0.08)
        desv = np.max(np.abs(np.array(norms) - 1.0))
        ax.set_title(f"Conservación de norma  ψ†Mψ   (desv. máx = {desv:.2e})",
                     color=TEXT, fontfamily="monospace", fontsize=10)
        ax.set_xlabel("t (tiempo físico)", color=MUTED)
        ax.set_ylabel("‖ψ‖²", color=MUTED)
        ax.legend(facecolor=CARD, edgecolor=BORDER, labelcolor=TEXT, fontsize=9)
        plt.tight_layout(); plt.show()

    def energy(self):
        if not self._check_sol(): return
        dt_val = float(self.edt.get())
        t_axis = np.arange(len(self.sol)) * dt_val
        coef_K = (hbar**2) / (2 * m)
        H_pre  = coef_K * self.K_csr + self.V_csr
        E = []
        for p in self.sol:
            num = np.real(np.dot(np.conj(p), H_pre @ p))
            den = np.real(np.dot(np.conj(p), self.M_csr @ p))
            E.append(num / den if den > 1e-30 else 0.0)
        E = np.array(E)
        fig, axes = plt.subplots(1, 2, figsize=(12, 5), facecolor=PLT_BG)
        
        aplicar_tema_ax(axes[0], "Energía esperada  ⟨H⟩ vs t")
        axes[0].plot(t_axis, E, color=INFO, lw=1.8)
        if self.var_pot.get() == "Armónico":
            axes[0].axhline(1.0, color=WARN, ls="--", lw=0.9,
                            label="E₀ exacta (harm. 2D) = 1.0")
            axes[0].legend(facecolor=CARD, edgecolor=BORDER,
                           labelcolor=TEXT, fontsize=8)
        axes[0].set_xlabel("t", color=MUTED)
        axes[0].set_ylabel("⟨E⟩", color=MUTED)
        
        aplicar_tema_ax(axes[1], "Fluctuación de ⟨H⟩ (E - E₀)")
        E0 = E[0]
        axes[1].plot(t_axis, E - E0, color=ACCENT2, lw=1.5)
        axes[1].axhline(0, color=DIM, ls="--", lw=0.8)
        axes[1].set_xlabel("t", color=MUTED)
        axes[1].set_ylabel("ΔE", color=MUTED)
        plt.tight_layout(); plt.show()

    def show_posicion(self):
        """Grafica ⟨x⟩(t) y ⟨y⟩(t) — trayectoria del centroide."""
        if not self._check_sol(): return
        dt_val = float(self.edt.get())
        t_axis = np.arange(len(self.sol)) * dt_val
        exs, eys = [], []
        for p in self.sol:
            ex, ey = posicion_esperada(p, self.XX, self.YY, self.M_csr)
            exs.append(ex); eys.append(ey)
        fig, axes = plt.subplots(1, 2, figsize=(12, 5), facecolor=PLT_BG)
        aplicar_tema_ax(axes[0], "⟨x⟩(t)  y  ⟨y⟩(t)")
        axes[0].plot(t_axis, exs, color=ACCENT,  lw=1.8, label="⟨x⟩")
        axes[0].plot(t_axis, eys, color=INFO,    lw=1.8, label="⟨y⟩")
        axes[0].set_xlabel("t", color=MUTED)
        axes[0].set_ylabel("posición esperada", color=MUTED)
        axes[0].legend(facecolor=CARD, edgecolor=BORDER, labelcolor=TEXT)
        aplicar_tema_ax(axes[1], "Trayectoria  ⟨x⟩ vs ⟨y⟩")
        sc = axes[1].scatter(exs, eys, c=t_axis,
                             cmap="plasma", s=6)
        cb = fig.colorbar(sc, ax=axes[1], pad=0.02)
        cb.ax.tick_params(colors=MUTED, labelsize=7)
        cb.set_label("t", color=MUTED)
        axes[1].set_xlabel("⟨x⟩", color=MUTED)
        axes[1].set_ylabel("⟨y⟩", color=MUTED)
        plt.tight_layout(); plt.show()

    def show_convergencia(self):
