def crear_malla_2d(Nx, Ny, Lx=8.0, Ly=8.0):
    """
    Devuelve:
      x, y  : arrays 1D de coordenadas
      XX, YY: meshgrids
      hx, hy: tamaños de elemento
    """
    x  = np.linspace(-Lx, Lx, Nx)
    y  = np.linspace(-Ly, Ly, Ny)
    XX, YY = np.meshgrid(x, y)          # shape (Ny, Nx)
    hx = x[1] - x[0]
    hy = y[1] - y[0]
    return x, y, XX, YY, hx, hy

def idx(i, j, Nx):
    """Índice global del nodo (i,j) → fila i, columna j."""
    return i * Nx + j


def ensamblar_2d_lil(Nx, Ny, hx, hy):
    
    N   = Nx * Ny
    # Crear en formato LIL 
    M_lil = lil_matrix((N, N), dtype=complex)
    K_lil = lil_matrix((N, N), dtype=complex)

    # Matrices elementales Q4 analíticas (integración exacta 2×2 Gauss)
    Me, Ke = _elem_matrices_q4(hx, hy)

    for i in range(Ny - 1):          # filas de elementos
        for j in range(Nx - 1):      # columnas de elementos
            # índices globales de los 4 nodos del elemento
            dofs = [
                idx(i,   j,   Nx),   # 0
                idx(i,   j+1, Nx),   # 1
                idx(i+1, j+1, Nx),   # 2
                idx(i+1, j,   Nx),   # 3
            ]
            # Ensamblaje en LIL (inserción eficiente)
            for a in range(4):
                for b in range(4):
                    M_lil[dofs[a], dofs[b]] += Me[a, b]
                    K_lil[dofs[a], dofs[b]] += Ke[a, b]

    
    M_csr = M_lil.tocsr()
    K_csr = K_lil.tocsr()
    return M_csr, K_csr


def ensamblar_V_2d_dok(V_flat):
    """
    Construye la matriz diagonal del potencial usando DOK
    (Dictionary of Keys), luego convierte a CSR.
    DOK es ideal para matrices con entradas en posiciones arbitrarias.
    Solo almacena entradas significativas (|V| > umbral).
    """
    N     = len(V_flat)
    V_dok = dok_matrix((N, N), dtype=complex)
    for i, v in enumerate(V_flat):
        if abs(v) > 1e-15:          # umbral robusto frente a NaN/subnormals
            V_dok[i, i] = complex(v)
    
    return V_dok.tocsr()


def _elem_matrices_q4(hx, hy):
    """
    Matrices de masa y rigidez para elemento cuadrilátero Q4
    mediante integración de Gauss 2×2.
    """
    # Puntos y pesos de Gauss en [-1,1]
    gp = np.array([-1, 1]) / np.sqrt(3)
    gw = np.array([1.0, 1.0])

    Me = np.zeros((4, 4))
    Ke = np.zeros((4, 4))

    for xi, wx in zip(gp, gw):
        for eta, wy in zip(gp, gw):
            # Funciones de forma N_a(xi, eta)
            N = 0.25 * np.array([
                (1 - xi) * (1 - eta),
                (1 + xi) * (1 - eta),
                (1 + xi) * (1 + eta),
                (1 - xi) * (1 + eta),
            ])
            # Derivadas ∂N/∂xi  y  ∂N/∂eta
            dN_dxi  = 0.25 * np.array([-(1-eta),  (1-eta),  (1+eta), -(1+eta)])
            dN_deta = 0.25 * np.array([-(1-xi),  -(1+xi),   (1+xi),  (1-xi) ])

            # Jacobiano  J = [[dx/dxi, dy/dxi],[dx/deta, dy/deta]]
            # Para elemento rectangular: dx/dxi = hx/2, dy/deta = hy/2
            jac  = (hx / 2) * (hy / 2)   # det(J)

            # Gradientes en coordenadas físicas
            dN_dx = dN_dxi  * (2 / hx)
            dN_dy = dN_deta * (2 / hy)

            w = wx * wy * jac

            Me += w * np.outer(N, N)
            Ke += w * (np.outer(dN_dx, dN_dx) + np.outer(dN_dy, dN_dy))

    return Me, Ke



def aplicar_dirichlet_2d_csr(A, border_dofs):
    """
    Aplica condición ψ = 0 en los nodos del borde.
    Trabaja con la matriz en formato CSR (o LIL internamente).
    """
    A_lil = A.tolil()
    for dof in border_dofs:
        A_lil[dof, :] = 0
        A_lil[dof, dof] = 1
    return A_lil.tocsr()

def obtener_borde_dofs(Nx, Ny):
    dofs = set()
    for j in range(Nx):
        dofs.add(idx(0, j, Nx))
        dofs.add(idx(Ny-1, j, Nx))
    for i in range(Ny):
        dofs.add(idx(i, 0, Nx))
        dofs.add(idx(i, Nx-1, Nx))
    return list(dofs)



def potencial_2d(XX, YY, tipo):
    if tipo == "Libre":
        return np.zeros_like(XX)
    if tipo == "Armónico":
        return 0.5 * (XX**2 + YY**2)
    if tipo == "Barrera":
        V = np.zeros_like(XX)
        V[np.abs(XX) < 1.0] += 10.0
        return V
    if tipo == "Doble Pozo":
        return 0.5 * (XX**2 - 2)**2 * 0.3
    if tipo == "Barrera Doble":
        V = np.zeros_like(XX)
        V[(np.abs(XX - 1.5) < 0.4)] = 12.0
        V[(np.abs(XX + 1.5) < 0.4)] = 12.0
        return V
    if tipo == "Coulomb":
        r = np.sqrt(XX**2 + YY**2) + 0.5   # regularización
        return -1.0 / r
    if tipo == "Caja":
        V = np.zeros_like(XX)
        Lx = XX.max()
        V[np.abs(XX) > 0.85 * Lx] = 50.0
        V[np.abs(YY) > 0.85 * Lx] = 50.0
        return V
    return np.zeros_like(XX)


def posicion_esperada(psi, XX, YY, M_csr):
    """Valor esperado de posición: ⟨x⟩ y ⟨y⟩ en formulación FEM."""
    N = len(psi)
    Nx_Ny = XX.shape
    x_flat = XX.ravel()
    y_flat = YY.ravel()
    den  = np.real(np.dot(np.conj(psi), M_csr @ psi))
    xpsi = x_flat * psi
    ypsi = y_flat * psi
    ex   = np.real(np.dot(np.conj(psi), M_csr @ xpsi)) / den if den > 1e-30 else 0.0
    ey   = np.real(np.dot(np.conj(psi), M_csr @ ypsi)) / den if den > 1e-30 else 0.0
    return ex, ey


def convergencia_energia_2d(Nx_list, potencial="Armónico", dt=0.002, Nt=5):
    """
    Calcula ⟨H⟩ en el estado inicial para distintas mallas.
    Útil para demostrar convergencia h→0 en el informe.
    Devuelve (lista_h, lista_E).
    """
    hs, Es = [], []
    for Nx in Nx_list:
        x, y, XX, YY, hx, hy = crear_malla_2d(Nx, Nx)
        M, K = ensamblar_2d_lil(Nx, Nx, hx, hy)
        V2d  = potencial_2d(XX, YY, potencial)
        Vcsr = ensamblar_V_2d_dok(V2d.ravel())
        psi  = gaussiana_2d(XX, YY, x0=0.0, sx=0.8, kx=0.0)
        psi  = normalizar_2d(psi, hx, hy)
        psi  = renormalizar_fem(psi, M)
        E    = energia_2d(psi, K, Vcsr, M)
        hs.append(hx)
        Es.append(E)
    return np.array(hs), np.array(Es)

def gaussiana_2d(XX, YY, x0=-3, y0=0, sx=1.0, sy=1.0, kx=2, ky=0):
    psi = (np.exp(-((XX - x0)**2 / (2*sx**2) + (YY - y0)**2 / (2*sy**2)))
           * np.exp(1j * (kx*XX + ky*YY)))
    return psi.ravel()

def normalizar_2d(psi, hx, hy):
    # Aproximación cuadratura rectangular para condición inicial
    norm = np.sqrt(np.sum(np.abs(psi)**2) * hx * hy)
    if norm < 1e-30:
        raise ValueError("ψ₀ es casi cero — la gaussiana está fuera del dominio")
    return psi / norm

def renormalizar_fem(psi, M_csr):
    """Renormaliza usando la norma FEM consistente: ‖ψ‖² = ψ†Mψ"""
    norm2 = np.real(np.dot(np.conj(psi), M_csr @ psi))
    if norm2 < 1e-30:
        raise ValueError("Norma FEM casi cero — estado inválido")
    return psi / np.sqrt(norm2)



def schrodinger_CN_2d(M_csr, K_csr, V_csr, psi0, dt, Nt,
                      border_dofs, progress_cb=None):

    
    coef_K = (hbar**2) / (2 * m)
    coef_M = 1j * hbar / dt
    H = coef_K * K_csr + V_csr
    A = coef_M * M_csr + 0.5 * H
    B = coef_M * M_csr - 0.5 * H

    # Dirichlet: solo modificar A (ψ=0 en borde); en cada paso forzar rhs[borde]=0
    A = aplicar_dirichlet_2d_csr(A, border_dofs)
    border_arr = np.array(border_dofs, dtype=int)

    psi  = psi0.copy()
    psi[border_arr] = 0.0          # condición inicial cumple borde
    sol  = [psi.copy()]

    for step in range(Nt):
        rhs = B @ psi
        rhs[border_arr] = 0.0      # Dirichlet homogéneo en RHS
        psi = spsolve(A, rhs)
        sol.append(psi.copy())
        if progress_cb and step % max(1, Nt//20) == 0:
            progress_cb(int(30 + 70 * step / Nt))

    return np.array(sol)



def energia_2d(psi, K_csr, V_csr, M_csr):
    """
    Valor esperado del Hamiltoniano en formulación FEM:
        ⟨H⟩ = (ψ† H ψ) / (ψ† M ψ)
    donde H = (ℏ²/2m)·K + V
    """
    coef_K = (hbar**2) / (2 * m)
    H      = coef_K * K_csr + V_csr
    num    = np.real(np.dot(np.conj(psi), H @ psi))
    den    = np.real(np.dot(np.conj(psi), M_csr @ psi))
    return num / den if den > 1e-30 else 0.0



def aplicar_tema_ax(ax, titulo=""):
    ax.set_facecolor(PLT_FACE)
    ax.tick_params(colors=MUTED, labelsize=8)
    for spine in ax.spines.values():
        spine.set_edgecolor(BORDER)
    ax.xaxis.label.set_color(MUTED)
    ax.yaxis.label.set_color(MUTED)
    if titulo:
        ax.set_title(titulo, color=TEXT, fontsize=10, pad=10,
                     fontfamily="monospace")
    ax.grid(True, color=PLT_GRID, linewidth=0.5, linestyle="--", alpha=0.6)

def fig_externa(figsize=(7, 5)):
    fig, ax = plt.subplots(figsize=figsize, facecolor=PLT_BG)
    aplicar_tema_ax(ax)
    return fig, ax

def _lighten(hex_color, factor=0.15):
    hex_color = hex_color.lstrip("#")
    r, g, b = (int(hex_color[i:i+2], 16) for i in (0, 2, 4))
    r = min(255, int(r + (255-r)*factor))
    g = min(255, int(g + (255-g)*factor))
    b = min(255, int(b + (255-b)*factor))
    return f"#{r:02x}{g:02x}{b:02x}"



