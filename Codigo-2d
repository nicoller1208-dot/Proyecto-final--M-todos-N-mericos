        tk.Frame(parent, bg=BORDER, height=1).pack(fill="x")

        self.fig = Figure(figsize=(9, 6), facecolor=PLT_BG)
        self.fig.subplots_adjust(left=0.08, right=0.96,
                                 top=0.92, bottom=0.10)
        self.ax = self.fig.add_subplot(111)
        aplicar_tema_ax(self.ax, "")

        self.canvas_plot = FigureCanvasTkAgg(self.fig, master=parent)
        self.canvas_plot.get_tk_widget().pack(fill="both", expand=True)

        self.ax.text(0.5, 0.5, "Sin datos",
                     ha="center", va="center",
                     color=DIM, fontsize=14, fontfamily="monospace",
                     transform=self.ax.transAxes)
        self.canvas_plot.draw()

    
    def run(self):
        self._set_status("● CALCULANDO…", ACCENT)
        self.progress["value"] = 5
        self.root.update()
        try:
            self._run_inner()
        except Exception as e:
            self._set_status(f"● ERROR: {e}", DANGER)
            self.progress["value"] = 0

    def _run_inner(self):
        Nx = int(self.eNx.get())
        Ny = int(self.eNy.get())
        dt = float(self.edt.get())
        Nt = int(self.eNt.get())

        if Nx < 4 or Ny < 4:
            raise ValueError("Nx y Ny deben ser ≥ 4")
        if dt <= 0:
            raise ValueError("dt debe ser positivo")
        if Nt < 1:
            raise ValueError("Nt debe ser ≥ 1")

        self.Nx, self.Ny = Nx, Ny
        self.x, self.y, self.XX, self.YY, hx, hy = crear_malla_2d(Nx, Ny)

        
        self._set_status("● Ensamblando M, K  (LIL→CSR)…", INFO)
        self.root.update()
        M_csr, K_csr = ensamblar_2d_lil(Nx, Ny, hx, hy)

        self.progress["value"] = 20
        self.root.update()

        
        self._set_status("● Construyendo V  (DOK→CSR)…", INFO)
        self.root.update()
        V_2d   = potencial_2d(self.XX, self.YY, self.var_pot.get())
        V_flat = V_2d.ravel()
        V_csr  = ensamblar_V_2d_dok(V_flat)

        self.M_csr = M_csr
        self.K_csr = K_csr
        self.V_csr = V_csr
        self.V_flat = V_flat
        self.hx, self.hy = hx, hy

        
        x0_v = float(self.ex0.get())
        sx_v = float(self.esx.get())
        kx_v = float(self.ekx.get())
        psi0 = gaussiana_2d(self.XX, self.YY, x0=x0_v, sx=sx_v, kx=kx_v)
        psi0 = normalizar_2d(psi0, hx, hy)          # aprox. rectangular
        psi0 = renormalizar_fem(psi0, M_csr)         # renorm. FEM exacta

        border_dofs = obtener_borde_dofs(Nx, Ny)

        self.progress["value"] = 30
        self.root.update()

        
        self._set_status("● Resolviendo CN  (CSR spsolve)…", INFO)
        self.root.update()

        self.sol = schrodinger_CN_2d(
            M_csr, K_csr, V_csr, psi0, dt, Nt,
            border_dofs,
            progress_cb=lambda v: (
                self.progress.__setitem__("value", v),
                self.root.update()
            )
        )

        self.progress["value"] = 100
        self._plot_final(Nx, Ny, Nt, dt)
        self._set_status("● LISTO", SUCCESS)

    def _plot_final(self, Nx, Ny, Nt, dt):
        prob    = np.abs(self.sol[-1])**2
        prob_2d = prob.reshape(Ny, Nx)
        cmap    = self.var_cmap.get()

        self.ax.clear()
        aplicar_tema_ax(self.ax, f"|ψ|²  —  paso final  (Nt={Nt})")

        im = self.ax.pcolormesh(self.XX, self.YY, prob_2d,
                                cmap=cmap, shading="auto")
        # Superponer contorno del potencial (si no es libre)
        if self.var_pot.get() != "Libre" and hasattr(self, "V_flat"):
            V_2d = self.V_flat.reshape(Ny, Nx)
            vmax_V = V_2d.max()
            if vmax_V > 1e-10:
                self.ax.contour(self.XX, self.YY, V_2d,
                                levels=6, colors="white", alpha=0.35,
                                linewidths=0.7)
        if hasattr(self, "_colorbar") and self._colorbar:
            try: self._colorbar.remove()
            except Exception: pass
        self._colorbar = self.fig.colorbar(im, ax=self.ax, pad=0.02)
        self._colorbar.ax.tick_params(colors=MUTED, labelsize=7)

        self.ax.set_xlabel("x", color=MUTED)
        self.ax.set_ylabel("y", color=MUTED)
        self.canvas_plot.draw()

        self.lbl_plot_title.config(
            text=f"|ψ|²  ·  {Nx}×{Ny}  dt={dt}  Nt={Nt}  V={self.var_pot.get()}  cmap={cmap}",
            fg=TEXT)

    def animate(self):
        if not self._check_sol(): return
        if self.Nx is None or self.Ny is None:
            self._set_status("● Faltan dimensiones de malla", DANGER)
            return
        Nx, Ny = self.Nx, self.Ny
        cmap = self.var_cmap.get()

        plt.style.use("dark_background")
        fig, ax = plt.subplots(figsize=(7, 6), facecolor=PLT_BG)
        aplicar_tema_ax(ax, "Evolución temporal de |ψ|²")

        prob0 = (np.abs(self.sol[0])**2).reshape(Ny, Nx)
        vmax  = float(np.max(np.abs(self.sol)**2)) * 1.05
        im = ax.pcolormesh(self.XX, self.YY, prob0,
                           cmap=cmap, shading="auto",
                           vmin=0, vmax=vmax)
        fig.colorbar(im, ax=ax, pad=0.02)

        # Contorno del potencial fijo
        if self.var_pot.get() != "Libre" and hasattr(self, "V_flat"):
            V_2d = self.V_flat.reshape(Ny, Nx)
            if V_2d.max() > 1e-10:
                ax.contour(self.XX, self.YY, V_2d,
                           levels=5, colors="white", alpha=0.3, linewidths=0.6)

        time_txt = ax.text(0.02, 0.96, "t = 0.000",
                           transform=ax.transAxes,
                           color=TEXT, fontsize=9, fontfamily="monospace",
                           verticalalignment="top")
        dt_val = float(self.edt.get())

        def update(i):
            prob = (np.abs(self.sol[i])**2).reshape(Ny, Nx)
            im.set_array(prob.ravel())
            time_txt.set_text(f"t = {i * dt_val:.3f}  (paso {i:04d})")
            return im, time_txt

        self._ani = FuncAnimation(fig, update,
                                  frames=len(self.sol),
                                  interval=45, blit=True)
        plt.tight_layout()
        plt.show()

